<div class="card" style="margin-bottom: 1rem;">
  <div class="card-content">
    <div class="media">
      <div class="media-left">
        <figure class="image is-64x64">
          <% if customer.image.attached? %>
            <%= image_tag customer.image, style: "width:64px;height:64px;object-fit:cover;" %>
          <% else %>
            <img src="https://bulma.io/images/placeholders/64x64.png" alt="No image">
          <% end %>
        </figure>
      </div>
      <div class="media-content">
        <p class="title is-5"><%= customer.full_name %></p>
        <p class="subtitle is-6"><%= customer.email_address.present? ? customer.email_address : "No email on file" %></p>
      </div>
    </div>
    <div class="content">
      <p><strong>📞</strong> <%= customer.phone_number.present? ? customer.phone_number : "N/A" %></p>
      <p><strong>📝</strong> <%= customer.notes.present? ? customer.notes : "No notes" %></p>
    </div>
  </div>
</div>