<section class="section">
  <div class="container">
    <h1 class="title">Customers (A–Z)</h1>
    <div class="buttons">
      <%= link_to "All Customers", root_path, class: "button is-light" %>
      <%= link_to "Missing Email", missing_email_path, class: "button is-warning" %>
    </div>
    <% @customers.each do |customer| %>
      <%= render partial: "customer", locals: { customer: customer } %>
    <% end %>
  </div>
</section>